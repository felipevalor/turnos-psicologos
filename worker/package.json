{
  "name": "turnospsi-worker",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev --config ../wrangler.toml",
    "deploy": "wrangler deploy --config ../wrangler.toml",
    "db:schema": "wrangler d1 execute DB --config ../wrangler.toml --local --file=src/db/schema.sql",
    "db:seed": "npx tsx scripts/seed.ts",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@kapso/whatsapp-cloud-api": "^0.2.0",
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241127.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.1",
    "wrangler": "^3.80.0"
  }
}
